---
interface Props {
  title: string;
  description?: string;
}
const { title, description = 'ANAVA SOMA — Ganzheitliche Rückverbindung für Frauen ab 40. Nervensystemregulation, Ayurveda und Heilung durch echte Erfahrung.' } = Astro.props;
---
<!doctype html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title} | ANAVA SOMA</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400;1,600&family=Manrope:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/styles/global.css" />
</head>
<body>
  <header class="site-header">
    <div class="gold-line"></div>
    <div class="container header-inner">
      <a href="/" class="logo">
        <span class="logo-main">ANAVA SOMA</span>
        <span class="logo-sub">von Tamara Sauer</span>
      </a>
      <nav class="nav">
        <a href="/ueber-mara">Über Mara</a>
        <a href="/angebote">Angebote</a>
        <a href="/ayurveda-test">Ayurveda-Test</a>
        <a href="/journal">Journal</a>
        <a href="/kontakt" class="btn btn-filled nav-cta">Erstgespräch</a>
      </nav>
      <button class="burger" aria-label="Menü öffnen">
        <span></span><span></span><span></span>
      </button>
    </div>
    <div class="gold-line"></div>
  </header>

  <main>
    <slot />
  </main>

  <footer class="site-footer">
    <div class="gold-line"></div>
    <div class="container footer-inner">
      <div class="footer-brand">
        <span class="logo-main" style="color: var(--cream); display:block; margin-bottom:0.3rem;">ANAVA SOMA</span>
        <span class="logo-sub" style="color: var(--gold); display:block; margin-bottom:1rem;">von Tamara Sauer</span>
        <p>Ganzheitliche Rückverbindung<br/>für Frauen ab 40.</p>
      </div>
      <nav class="footer-nav">
        <a href="/ueber-mara">Über Mara</a>
        <a href="/angebote">Angebote</a>
        <a href="/ayurveda-test">Ayurveda-Test</a>
        <a href="/journal">Journal</a>
        <a href="/kontakt">Kontakt</a>
        <a href="/impressum">Impressum</a>
        <a href="/datenschutz">Datenschutz</a>
      </nav>
      <div class="footer-claim">
        <span class="ornament">✦ ✦ ✦</span>
        <p class="brand-claim">„Das Nervensystem<br/>darf ausatmen."</p>
        <p class="copyright">© 2025 Tamara Sauer</p>
      </div>
    </div>
    <div class="gold-line" style="margin-top:3rem;"></div>
  </footer>
</body>
</html>

<style>
.site-header {
  position: sticky;
  top: 0;
  z-index: 100;
  background: var(--cream);
  padding: 0;
}

.header-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 2rem;
  padding: 1.2rem 0;
}

.logo-main {
  font-family: var(--font-serif);
  font-size: 1.35rem;
  letter-spacing: 0.18em;
  color: var(--charcoal);
}

.logo-sub {
  display: block;
  font-family: var(--font-sans);
  font-size: 0.65rem;
  font-weight: 400;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--gold);
  margin-top: 0.15rem;
}

.nav {
  display: flex;
  align-items: center;
  gap: 2.2rem;
}

.nav a:not(.btn) {
  font-size: 0.72rem;
  font-weight: 500;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--warm-gray);
  transition: color 0.2s;
}

.nav a:not(.btn):hover { color: var(--warm-brown); }

.nav-cta { font-size: 0.72rem; padding: 0.65rem 1.5rem; }

.burger {
  display: none;
  flex-direction: column;
  gap: 5px;
  background: none;
  border: none;
  cursor: pointer;
  padding: 4px;
}
.burger span {
  display: block;
  width: 22px;
  height: 1px;
  background: var(--charcoal);
  transition: all 0.3s;
}

@media (max-width: 768px) {
  .nav { display: none; }
  .burger { display: flex; }
}

/* Footer */
.site-footer {
  background: var(--charcoal);
  color: var(--sand);
  padding: 4rem 0 0;
}

.footer-inner {
  display: grid;
  grid-template-columns: 1.2fr 1fr 1fr;
  gap: 4rem;
  align-items: start;
  padding-bottom: 3rem;
}

.footer-brand p {
  font-size: 0.85rem;
  color: var(--warm-gray);
  line-height: 1.7;
}

.footer-nav {
  display: flex;
  flex-direction: column;
  gap: 0.7rem;
  padding-top: 0.3rem;
}

.footer-nav a {
  font-size: 0.75rem;
  font-weight: 400;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--taupe);
  transition: color 0.2s;
}

.footer-nav a:hover { color: var(--gold); }

.footer-claim {
  text-align: right;
}

.brand-claim {
  font-family: var(--font-serif);
  font-size: 1.3rem;
  font-style: italic;
  color: var(--cream);
  line-height: 1.5;
  margin: 0.5rem 0 1.5rem;
  max-width: none;
}

.copyright {
  font-size: 0.7rem;
  letter-spacing: 0.1em;
  color: var(--warm-gray);
  max-width: none;
}

@media (max-width: 768px) {
  .footer-inner { grid-template-columns: 1fr; }
  .footer-claim { text-align: left; }
}
</style>
