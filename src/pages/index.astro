---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Startseite">

  <!-- ═══ HERO — Vollbild, dunkel, atmosphärisch ═══ -->
  <section class="hero">
    <div class="hero-bg">
      <img src="/images/tamara-portrait.jpg" alt="" class="hero-bg-img" />
      <div class="hero-overlay"></div>
    </div>
    <div class="hero-content">
      <span class="script-lg fade-up">Tamara Sauer</span>
      <h1 class="fade-up delay-1">
        Du hast lang genug<br/>
        <em>funktioniert.</em>
      </h1>
      <div class="gold-line hero-line fade-up delay-2"></div>
      <p class="hero-sub fade-up delay-3">
        Nervensystemregulation · Ayurveda · Heilung<br/>
        Begleitung für Frauen ab 40
      </p>
      <div class="hero-actions fade-up delay-4">
        <a href="/kontakt" class="btn btn-gold">Erstgespräch anfragen</a>
        <a href="/angebote" class="btn btn-outline-light">Angebote entdecken</a>
      </div>
    </div>
    <a href="#signal" class="scroll-indicator" aria-label="Weiter scrollen">
      <span class="scroll-icon"></span>
    </a>
  </section>

  <!-- ═══ SIGNAL — Dunkel, Zitat ═══ -->
  <section class="section-dark signal-section" id="signal">
    <div class="container text-center">
      <div class="fade-up">
        <div class="gold-line" style="width:4rem; margin:0 auto 2.5rem;"></div>
        <span class="script" style="font-size:1.8rem; margin-bottom:1.5rem;">Mein Credo</span>
        <blockquote class="signal-quote">
          „Wenn es einen Auslöser dafür gab,<br/>dann gibt es auch einen dagegen."
        </blockquote>
        <cite class="signal-cite">— Tamara Sauer, Ayurveda Therapeutin</cite>
        <div class="gold-line" style="width:4rem; margin:2.5rem auto 0;"></div>
      </div>
    </div>
  </section>

  <!-- ═══ ÜBER MARA — Hell, asymmetrisch ═══ -->
  <section class="section-cream about-section">
    <div class="container about-inner">
      <div class="about-image-col fade-left">
        <div class="about-main-img-wrap">
          <img
            src="/images/tamara-portrait.jpg"
            alt="Tamara Sauer — Ayurveda Therapeutin"
            class="about-main-img"
          />
        </div>
        <div class="about-float-circle">
          <img
            src="/images/tamara-portrait.jpg"
            alt="Tamara"
            class="about-float-img"
          />
        </div>
      </div>
      <div class="about-text-col fade-right delay-2">
        <span class="script">Willkommen</span>
        <span class="section-label">Wer ich bin</span>
        <h2>Ich war dort,<br/>wo du gerade bist.</h2>
        <div class="divider"></div>
        <div class="about-text">
          <p>Alleinerziehende Mutter, Hair & Make-up Artist, Kostümbildnerin — und irgendwann
          am Ende meiner Kräfte. Mein Nervensystem kollabierte. Die Diagnose: unheilbar krank.</p>
          <p>Ich habe sie nicht akzeptiert.</p>
          <p>Heute bin ich gesund. Nicht durch Abkürzungen, sondern durch den Willen,
          wirklich hinzuschauen. Durch Ayurveda, Fasten, Journaling — und die Kraft
          echter Frauenverbindung.</p>
        </div>
        <div class="about-tags">
          {["Ayurveda", "Nervensystemregulation", "Trauma-Arbeit", "Ernährung", "Darmgesundheit", "Frauengesundheit"].map(tag => (
            <span class="tag">{tag}</span>
          ))}
        </div>
        <a href="/ueber-mara" class="btn btn-filled" style="margin-top:2.5rem">Meine Geschichte lesen</a>
      </div>
    </div>
  </section>

  <!-- ═══ THEMEN — Dunkel mit Glasmorphism ═══ -->
  <section class="section-dark themes-section">
    <div class="hero-bg themes-bg">
      <img src="/images/tamara-portrait.jpg" alt="" class="hero-bg-img" />
      <div class="hero-overlay" style="background: rgba(46,39,33,0.93);"></div>
    </div>
    <div class="container" style="position:relative; z-index:2;">
      <div class="text-center fade-up">
        <div class="gold-line" style="width:4rem; margin: 0 auto 2rem;"></div>
        <span class="script">Erkennst du dich?</span>
        <span class="section-label-light" style="display:block; text-align:center; margin-top:0.5rem;">Was dich hierher bringt</span>
        <h2 style="color:var(--cream); margin-top:0.5rem;">Du bist nicht allein.</h2>
        <div class="gold-line" style="width:4rem; margin: 2rem auto 4rem;"></div>
      </div>
      <div class="themes-grid">
        {[
          { icon: '✦', col: 'var(--gold)', title: 'Erschöpfung & Dysregulation', text: 'Du funktionierst — aber irgendwann geht es nicht mehr. Dein Nervensystem kennt keinen echten Ruhezustand.', delay: '' },
          { icon: '✦', col: 'var(--rose)', title: 'Hormonelle Beschwerden & PMS', text: 'Dein Körper spricht eine Sprache, die du noch nicht ganz verstehst. Ayurveda kann übersetzen.', delay: 'delay-1' },
          { icon: '✦', col: 'var(--terracotta)', title: 'Trauma & gespeicherter Schmerz', text: 'Was nicht verarbeitet wurde, lebt im Körper. Körperorientierte Arbeit löst, was Reden allein nicht kann.', delay: 'delay-2' },
          { icon: '✦', col: 'var(--sage)', title: 'Funktionsmodus statt Verbindung', text: 'Du weißt nicht mehr, wer du bist — jenseits der Rolle. Hier findest du zurück zu dir.', delay: 'delay-3' },
        ].map(({ icon, col, title, text, delay }) => (
          <div class={`card-glass theme-card fade-up ${delay}`}>
            <span style={`color: ${col}; font-size:1rem; display:block; margin-bottom:1.5rem;`}>{icon}</span>
            <h3 style="color:var(--cream); font-size:1.3rem; margin-bottom:0.8rem;">{title}</h3>
            <p style="color:rgba(245,239,230,0.6); font-size:0.9rem; line-height:1.75;">{text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ ANGEBOTE — Hell, Karten mit Goldakzent ═══ -->
  <section class="section-cream">
    <div class="container">
      <div class="fade-up text-center" style="margin-bottom:4rem;">
        <span class="script">Womit ich dich begleite</span>
        <span class="section-label" style="display:block; margin-top:0.5rem;">Angebote</span>
        <h2>Drei Wege zurück<br/>zu dir selbst.</h2>
        <div class="gold-line" style="width:4rem; margin:2rem auto 0;"></div>
      </div>
      <div class="offers-grid">
        {[
          { num: '01', col: 'var(--gold)', title: '1:1 Begleitung', text: 'Individuelle, tiefe Begleitung. Wir schauen auf dein Nervensystem, deine Ernährung, deinen Körper und deine Geschichte — und entwickeln einen Weg, der wirklich zu dir passt.', href: '/angebote#eins-zu-eins', delay: '' },
          { num: '02', col: 'var(--rose)', title: 'Nervensystem & Ernährung', text: 'Praktische Beratung, die Wissenschaft mit Ayurveda verbindet. Für deinen Konstitutionstyp, deine Beschwerden, dein Leben.', href: '/angebote#beratung', delay: 'delay-2' },
          { num: '03', col: 'var(--sage)', title: 'Workshops & Gruppen', text: 'Thematische Workshops für Frauen, die in Gemeinschaft wachsen wollen. Wissen, das du direkt anwenden kannst.', href: '/angebote#workshops', delay: 'delay-4' },
        ].map(({ num, col, title, text, href, delay }) => (
          <a href={href} class={`offer-card fade-up ${delay}`}>
            <span class="offer-num" style={`color: ${col};`}>{num}</span>
            <div class="gold-line" style="margin: 1.2rem 0;"></div>
            <h3>{title}</h3>
            <p>{text}</p>
            <span class="offer-cta">Mehr erfahren →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ CTA — Dunkel, atmosphärisch ═══ -->
  <section class="section-dark cta-section">
    <div class="container text-center">
      <div class="fade-up">
        <div class="gold-line" style="width:4rem; margin:0 auto 2.5rem;"></div>
        <span class="script" style="font-size:2rem;">Bereit?</span>
        <h2 style="color:var(--cream); margin: 1rem 0 1.5rem;">
          Ein erstes Gespräch.<br/>Kostenlos & ehrlich.
        </h2>
        <p style="color:var(--taupe); margin:0 auto 3rem; max-width:48ch; font-size:0.95rem;">
          Kein Druck, kein Verkauf. Nur ein ehrliches Gespräch darüber,
          wo du gerade stehst — und ob ich die richtige Begleitung für dich bin.
        </p>
        <div style="display:flex; gap:1.2rem; justify-content:center; flex-wrap:wrap;">
          <a href="/kontakt" class="btn btn-gold">Erstgespräch anfragen</a>
          <a href="/ayurveda-test" class="btn btn-outline-light">Ayurveda-Test machen</a>
        </div>
        <div class="gold-line" style="width:4rem; margin:3rem auto 0;"></div>
      </div>
    </div>
  </section>

</Layout>

<style>
/* ─── HERO ───────────────────────────────────── */
.hero {
  position: relative;
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.hero-bg {
  position: absolute;
  inset: 0;
}

.hero-bg-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center top;
}

.hero-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    to bottom,
    rgba(46,39,33,0.65) 0%,
    rgba(46,39,33,0.50) 40%,
    rgba(46,39,33,0.80) 100%
  );
}

.hero-content {
  position: relative;
  z-index: 2;
  text-align: center;
  padding: 2rem;
  max-width: 800px;
}

.hero-content .script-lg {
  color: var(--gold-light);
  font-size: 2rem;
  display: block;
  margin-bottom: 1rem;
}

.hero-content h1 {
  color: var(--cream);
  font-size: clamp(3rem, 7vw, 5.5rem);
  font-weight: 300;
  line-height: 1.1;
  margin-bottom: 0;
}

.hero-content h1 em {
  color: var(--gold);
  font-style: italic;
}

.hero-line {
  width: 5rem;
  margin: 2rem auto;
}

.hero-sub {
  color: rgba(245,239,230,0.75);
  font-size: 1rem;
  letter-spacing: 0.04em;
  margin: 0 auto 2.5rem;
  line-height: 2;
}

.hero-actions {
  display: flex;
  gap: 1.2rem;
  justify-content: center;
  flex-wrap: wrap;
}

.scroll-indicator {
  position: absolute;
  bottom: 2.5rem;
  left: 50%;
  transform: translateX(-50%);
  z-index: 2;
}

.scroll-icon {
  display: block;
  width: 1px;
  height: 50px;
  background: linear-gradient(to bottom, var(--gold), transparent);
  margin: 0 auto;
  animation: scrollPulse 2s ease-in-out infinite;
}

@keyframes scrollPulse {
  0%, 100% { opacity: 0.3; transform: scaleY(1); }
  50% { opacity: 0.8; transform: scaleY(1.1); }
}

/* ─── SIGNAL ─────────────────────────────────── */
.signal-section { padding: 6rem 0; }
.signal-quote {
  font-family: var(--font-serif);
  font-size: clamp(1.4rem, 3vw, 2.4rem);
  font-style: italic;
  color: var(--cream);
  max-width: 700px;
  margin: 0 auto 1.5rem;
  line-height: 1.5;
  font-weight: 300;
}
.signal-cite {
  font-size: 0.7rem;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--gold);
  font-style: normal;
}

/* ─── ABOUT ──────────────────────────────────── */
.about-section { overflow: hidden; }
.about-inner {
  display: grid;
  grid-template-columns: 1fr 1.2fr;
  gap: 6rem;
  align-items: center;
}
.about-image-col { position: relative; padding-bottom: 3rem; }
.about-main-img-wrap { position: relative; }
.about-main-img {
  width: 100%;
  max-width: 420px;
  aspect-ratio: 3/4;
  object-fit: cover;
  object-position: center top;
  border-radius: 2px;
  box-shadow: 0 20px 60px rgba(46,39,33,0.15);
}
.about-float-circle {
  position: absolute;
  bottom: -1rem;
  right: -2rem;
  width: 9rem;
  height: 9rem;
  border-radius: 50%;
  overflow: hidden;
  border: 3px solid var(--cream);
  box-shadow: 0 0 30px rgba(201,168,124,0.2);
}
.about-float-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center top;
}
.about-text-col h2 { margin: 0.5rem 0; }
.about-text { margin-top: 0; }
.about-text p {
  color: var(--warm-gray);
  margin-bottom: 1rem;
  font-size: 0.95rem;
}
.about-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 0.6rem;
  margin-top: 2rem;
}

/* ─── THEMES ─────────────────────────────────── */
.themes-section { position: relative; }
.themes-bg { z-index: 0; }
.themes-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
  gap: 1.5rem;
}
.theme-card { padding: 2.5rem 2rem; }

/* ─── OFFERS ─────────────────────────────────── */
.offers-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 2rem;
}
.offer-card {
  display: flex;
  flex-direction: column;
  gap: 0;
  padding: 2.5rem 2rem;
  background: var(--white);
  border: 1px solid var(--sand);
  transition: border-color 0.3s, box-shadow 0.3s, transform 0.3s;
}
.offer-card:hover {
  border-color: var(--gold);
  box-shadow: 0 8px 32px rgba(201,168,124,0.1);
  transform: translateY(-4px);
}
.offer-num {
  font-family: var(--font-serif);
  font-size: 3rem;
  line-height: 1;
  font-weight: 300;
}
.offer-card h3 { margin: 1.2rem 0 0.8rem; font-size: 1.3rem; }
.offer-card p {
  font-size: 0.88rem;
  color: var(--warm-gray);
  flex: 1;
  margin-bottom: 1.5rem;
}
.offer-cta {
  font-size: 0.75rem;
  letter-spacing: 0.1em;
  color: var(--terracotta);
  margin-top: auto;
}

/* ─── CTA ────────────────────────────────────── */
.cta-section { padding: 8rem 0; }

/* ─── HELPER ─────────────────────────────────── */
.text-center { text-align: center; }
.text-center p, .text-center h2 { margin-left: auto; margin-right: auto; }

@media (max-width: 900px) {
  .offers-grid { grid-template-columns: 1fr; }
}
@media (max-width: 768px) {
  .about-inner { grid-template-columns: 1fr; gap: 3rem; }
  .about-float-circle { right: 1rem; }
  .hero-content h1 { font-size: clamp(2.5rem, 10vw, 4rem); }
}
</style>
