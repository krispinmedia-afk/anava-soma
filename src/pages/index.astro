---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Startseite">

  <!-- HERO -->
  <section class="hero">
    <div class="container hero-inner">
      <div class="hero-text">
        <p class="section-label">Heilung · Verbindung · Selbstwert</p>
        <h1>Du hast lang genug<br/><em>funktioniert.</em></h1>
        <div class="divider"></div>
        <p class="hero-sub">
          Wenn dein Körper dir ein Zeichen schickt — mit Erschöpfung, Dysregulation oder dem Gefühl,
          du kennst dich selbst nicht mehr — dann beginnt hier eine neue Möglichkeit.
        </p>
        <div class="hero-actions">
          <a href="/angebote" class="btn btn-filled">Meine Angebote</a>
          <a href="/ueber-mara" class="btn">Über Mara</a>
        </div>
      </div>
      <div class="hero-image-wrap">
        <img
          src="/images/tamara-portrait.jpg"
          alt="Tamara Sauer — Ayurveda Therapeutin"
          class="hero-image"
        />
        <div class="hero-image-caption">Tamara Sauer · Ayurveda Therapeutin</div>
      </div>
    </div>
  </section>

  <!-- GOLD DIVIDER -->
  <div class="gold-line"></div>

  <!-- SIGNAL-SATZ -->
  <section class="signal-section">
    <div class="container">
      <span class="ornament">✦</span>
      <blockquote>
        „Wenn es einen Auslöser dafür gab,<br/>dann gibt es auch einen dagegen."
        <cite>— Tamara Sauer</cite>
      </blockquote>
      <span class="ornament">✦</span>
    </div>
  </section>

  <div class="gold-line"></div>

  <!-- THEMEN -->
  <section class="themes-section">
    <div class="container">
      <p class="section-label">Was dich hierher bringt</p>
      <h2>Erkennst du dich?</h2>
      <div class="divider"></div>
      <div class="themes-grid">
        {[
          { icon: '✦', color: 'var(--gold)', title: 'Erschöpfung & Dysregulation', text: 'Du funktionierst — aber irgendwann geht es nicht mehr. Dein Nervensystem kennt keinen Ruhezustand.' },
          { icon: '✦', color: 'var(--rose)', title: 'Hormonelle Beschwerden & PMS', text: 'Dein Körper spricht eine Sprache, die du noch nicht verstehst. Ayurveda kann übersetzen.' },
          { icon: '✦', color: 'var(--terracotta)', title: 'Trauma & gespeicherter Schmerz', text: 'Was nicht verarbeitet wurde, lebt im Körper. Körperorientierte Arbeit löst, was Reden allein nicht kann.' },
          { icon: '✦', color: 'var(--sage)', title: 'Funktionsmodus statt Verbindung', text: 'Du weißt nicht mehr, wer du bist — jenseits der Rolle. Hier findest du zurück zu dir.' },
        ].map(({ icon, color, title, text }) => (
          <div class="theme-card">
            <span class="theme-icon" style={`color: ${color}`}>{icon}</span>
            <h3>{title}</h3>
            <p>{text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ÜBER MARA TEASER -->
  <section class="about-teaser">
    <div class="container about-teaser-inner">
      <div class="about-image-wrap">
        <img
          src="/images/tamara-portrait.jpg"
          alt="Tamara Sauer"
          class="about-image"
        />
        <div class="about-image-tag">Tamara · 44 Jahre</div>
      </div>
      <div class="about-text">
        <p class="section-label">Wer ich bin</p>
        <h2>Ich war dort,<br/>wo du gerade bist.</h2>
        <div class="divider"></div>
        <p>
          Nach psychischer Gewalt, dem Zusammenbruch meines Nervensystems und einer Diagnose,
          die ich nicht akzeptiert habe — bin ich heute gesund. Nicht durch Abkürzungen,
          sondern durch den Willen, hinzuschauen.
        </p>
        <p>
          Als Ayurveda Therapeutin, Hair & Make-up Artist und Frau mit echter Heilungsgeschichte
          begleite ich Frauen ab 40 zurück zu sich selbst.
        </p>
        <a href="/ueber-mara" class="btn" style="margin-top: 2.5rem;">Meine Geschichte lesen</a>
      </div>
    </div>
  </section>

  <!-- ANGEBOTE ÜBERSICHT -->
  <section class="offers-section">
    <div class="container">
      <p class="section-label">Womit ich dich begleite</p>
      <h2>Angebote</h2>
      <div class="divider"></div>
      <div class="offers-grid">
        {[
          { num: '01', title: '1:1 Begleitung', text: 'Individuelle Begleitung auf deinem Weg. Wir arbeiten mit Nervensystem, Ernährung, Körper und deiner Geschichte.', href: '/angebote#eins-zu-eins' },
          { num: '02', title: 'Nervensystem & Ernährung', text: 'Praktische Beratung, die Wissenschaft und Ayurveda verbindet. Für deinen Körper, deinen Typ, dein Leben.', href: '/angebote#beratung' },
          { num: '03', title: 'Workshops & Gruppen', text: 'Gemeinschaft mit Frauen, die verstehen, was du durchmachst. Wissen, das du direkt anwenden kannst.', href: '/angebote#workshops' },
        ].map(({ num, title, text, href }) => (
          <a href={href} class="offer-card">
            <span class="offer-num">{num}</span>
            <h3>{title}</h3>
            <p>{text}</p>
            <span class="offer-link">Mehr erfahren →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section">
    <div class="container">
      <span class="ornament" style="color: var(--gold); opacity: 0.8;">✦ ✦ ✦</span>
      <h2>Bereit, dich selbst<br/>wieder zu hören?</h2>
      <p>Ein kostenfreies Erstgespräch. Kein Druck. Nur ein ehrliches Gespräch darüber, wo du gerade stehst.</p>
      <a href="/kontakt" class="btn btn-gold">Erstgespräch anfragen</a>
    </div>
  </section>

</Layout>

<style>
/* HERO */
.hero {
  padding: 7rem 0 6rem;
  background: var(--white);
}
.hero-inner {
  display: grid;
  grid-template-columns: 1.1fr 1fr;
  gap: 5rem;
  align-items: center;
}
.hero-text h1 em {
  font-style: italic;
  color: var(--terracotta);
}
.hero-sub {
  margin: 0 0 3rem;
  color: var(--warm-gray);
  font-size: 1rem;
  line-height: 1.8;
}
.hero-actions { display: flex; gap: 1.2rem; flex-wrap: wrap; }
.hero-image-wrap { position: relative; }
.hero-image {
  width: 100%;
  aspect-ratio: 3/4;
  object-fit: cover;
  object-position: center top;
  border-radius: 1px;
}
.hero-image-caption {
  position: absolute;
  bottom: -1.5rem;
  right: 0;
  font-size: 0.65rem;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--gold);
}

/* SIGNAL */
.signal-section {
  background: var(--warm-brown);
  padding: 5rem 0;
  text-align: center;
}
.signal-section blockquote {
  font-family: var(--font-serif);
  font-size: clamp(1.4rem, 3vw, 2.2rem);
  font-style: italic;
  color: var(--cream);
  max-width: 680px;
  margin: 1rem auto;
  line-height: 1.5;
}
.signal-section cite {
  display: block;
  font-family: var(--font-sans);
  font-style: normal;
  font-size: 0.7rem;
  font-weight: 400;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  margin-top: 1.8rem;
  color: var(--gold);
}

/* THEMEN */
.themes-section { background: var(--cream); }
.themes-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
  gap: 1.5rem;
  margin-top: 3.5rem;
}
.theme-card {
  padding: 2.5rem 2rem;
  background: var(--white);
  border: 1px solid var(--sand);
  border-radius: 1px;
  transition: border-color 0.3s, box-shadow 0.3s;
}
.theme-card:hover {
  border-color: var(--gold);
  box-shadow: 0 4px 24px rgba(201,168,124,0.08);
}
.theme-icon {
  font-size: 1rem;
  display: block;
  margin-bottom: 1.5rem;
}
.theme-card h3 { margin-bottom: 0.8rem; font-size: 1.2rem; }
.theme-card p { font-size: 0.9rem; color: var(--warm-gray); }

/* ÜBER TEASER */
.about-teaser { background: var(--sand); }
.about-teaser-inner {
  display: grid;
  grid-template-columns: 1fr 1.3fr;
  gap: 6rem;
  align-items: center;
}
.about-image-wrap { position: relative; }
.about-image {
  width: 100%;
  aspect-ratio: 4/5;
  object-fit: cover;
  object-position: center top;
  border-radius: 1px;
}
.about-image-tag {
  position: absolute;
  bottom: -1.2rem;
  left: 0;
  font-size: 0.65rem;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--warm-brown);
}
.about-text p { color: var(--warm-gray); margin-bottom: 1.2rem; font-size: 0.95rem; }

/* ANGEBOTE */
.offers-section { background: var(--white); }
.offers-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 2rem;
  margin-top: 3.5rem;
}
.offer-card {
  display: flex;
  flex-direction: column;
  gap: 0.8rem;
  padding: 2.5rem 2rem;
  background: var(--cream);
  border-top: 1px solid var(--gold);
  transition: background 0.3s;
}
.offer-card:hover { background: var(--sand); }
.offer-num {
  font-family: var(--font-serif);
  font-size: 2.5rem;
  color: var(--rose);
  line-height: 1;
}
.offer-card h3 { font-size: 1.25rem; }
.offer-card p { font-size: 0.88rem; color: var(--warm-gray); flex: 1; }
.offer-link { font-size: 0.75rem; letter-spacing: 0.1em; color: var(--terracotta); margin-top: 1rem; }

/* CTA */
.cta-section {
  background: var(--charcoal);
  text-align: center;
  padding: 7rem 0;
}
.cta-section h2 {
  color: var(--cream);
  margin: 1.5rem auto;
}
.cta-section p {
  color: var(--taupe);
  margin: 0 auto 3rem;
  max-width: 48ch;
  font-size: 0.95rem;
}

@media (max-width: 900px) {
  .offers-grid { grid-template-columns: 1fr; }
}
@media (max-width: 768px) {
  .hero-inner, .about-teaser-inner { grid-template-columns: 1fr; }
  .hero-image-wrap { order: -1; }
}
</style>
